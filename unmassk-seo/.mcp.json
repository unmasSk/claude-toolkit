{
  "mcpServers": {
    "dataforseo": {
      "command": "npx",
      "args": ["-y", "dataforseo-mcp-server"],
      "env": {
        "DATAFORSEO_USERNAME": "${DATAFORSEO_USERNAME}",
        "DATAFORSEO_PASSWORD": "${DATAFORSEO_PASSWORD}",
        "ENABLED_MODULES": "serp,keywords_data,dataforseo_labs,backlinks,onpage,domain_analytics,business_data,content_analysis,ai_optimization",
        "FIELD_CONFIG_PATH": "${CLAUDE_PLUGIN_ROOT}/extensions/dataforseo/field-config.json"
      }
    },
    "ahrefs": {
      "command": "npx",
      "args": ["-y", "@ahrefs/mcp"],
      "env": {
        "AHREFS_API_KEY": "${AHREFS_API_KEY}"
      }
    },
    "semrush": {
      "type": "sse",
      "url": "https://mcp.semrush.com/v1/mcp",
      "env": {
        "SEMRUSH_API_KEY": "${SEMRUSH_API_KEY}"
      }
    },
    "google-search-console": {
      "command": "npx",
      "args": ["-y", "mcp-server-gsc"],
      "env": {
        "GSC_CREDENTIALS_PATH": "${GSC_CREDENTIALS_PATH}"
      }
    },
    "pagespeed": {
      "command": "npx",
      "args": ["-y", "mcp-server-pagespeed"],
      "env": {
        "PAGESPEED_API_KEY": "${PAGESPEED_API_KEY}"
      }
    }
  }
}
