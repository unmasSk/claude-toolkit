# Chatroom backend — environment variables
# Copy this file to .env and fill in any values you want to override.
# All variables have safe defaults and are optional unless noted.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# TCP port the Elysia HTTP/WS server binds to.
# Must be an integer between 1 and 65535.
# Default: 3000
PORT=3000

# Host/IP address the server binds to.
# Use 127.0.0.1 (loopback) to restrict access to the local machine.
# Use 0.0.0.0 to expose on all interfaces (e.g. Docker, remote dev).
# Default: 127.0.0.1
HOST=127.0.0.1

# Runtime environment. Controls CORS, origin checking, and static file serving.
# Must be one of: development, production, test
# Default: development
NODE_ENV=development

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Absolute or relative path to the SQLite database file.
# The directory is created automatically if it does not exist.
# Default: <src>/../data/chatroom.db  (resolved at runtime)
# DB_PATH=data/chatroom.db

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Pino log level. Controls the minimum severity level that is emitted.
# Must be one of: fatal, error, warn, info, debug, trace
# Default: debug
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Agents
# ---------------------------------------------------------------------------

# Absolute path to the directory containing agent .md definition files.
# If unset, the server auto-discovers the directory from the unmassk-toolkit
# plugin cache (~/.claude/plugins/cache/unmassk-claude-toolkit/...).
# Must point to an existing directory when set.
# Default: auto-discovered
# AGENT_DIR=/path/to/agents

# Maximum number of concurrent agent invocations across all rooms.
# Must be an integer between 1 and 20.
# Increase on machines with >16 GB RAM (each claude process uses ~1 GB RSS).
# Default: 3
MAX_CONCURRENT_AGENTS=3

# ---------------------------------------------------------------------------
# WebSocket
# ---------------------------------------------------------------------------

# Comma-separated list of allowed Origin header values for WebSocket upgrades.
# Each entry must be a valid http:// or https:// URL origin (scheme + host [+ port]).
# In development/test mode, connections with no Origin header are also accepted.
# Default: http://localhost:4201,http://127.0.0.1:4201
WS_ALLOWED_ORIGINS=http://localhost:4201,http://127.0.0.1:4201
