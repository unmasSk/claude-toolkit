{
  "name": "agent-chatroom",
  "version": "0.4.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"backend,frontend\" --prefix-colors \"cyan,magenta\" \"bun run dev:backend\" \"bun run dev:frontend\"",
    "tauri:dev": "concurrently --kill-others-on-fail --names \"backend,frontend\" --prefix-colors \"cyan,magenta\" \"bun run dev:backend\" \"cd apps/frontend && bun run tauri:dev\"",
    "dev:backend": "cd apps/backend && bun run dev",
    "dev:frontend": "cd apps/frontend && bun run dev",
    "build": "bun run build:shared && bun run build:frontend",
    "build:shared": "cd packages/shared && bun run build",
    "build:frontend": "cd apps/frontend && bun run build",
    "lint": "eslint apps/ packages/",
    "format": "prettier --write apps/ packages/",
    "format:check": "prettier --check apps/ packages/",
    "test:backend": "cd apps/backend && bun test",
    "test:frontend": "cd apps/frontend && npx vitest run",
    "check-all": "bun run build && bun run lint && bun run format:check && bun run test:backend && bun run test:frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.1"
  },
  "dependencies": {
    "helmet": "^8.1.0"
  }
}
